<aside class="toc sidebar" data-title="{{{or page.attributes.toctitle 'Contents'}}}" data-levels="{{{or page.attributes.toclevels 2}}}">
{{#if page.attributes.haiku}}
  <div class="toc-haiku">
    <p>{{{page.attributes.haiku}}}</p>
  </div>
  <script>!function(){var e=document.querySelector('.toc-haiku p');if(e)e.innerHTML=e.textContent.replace(/ \/ /g,'<br>')}()</script>
{{/if}}
  <div class="toc-menu"></div>
</aside>
